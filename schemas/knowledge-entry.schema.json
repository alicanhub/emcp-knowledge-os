{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://emcp.example/schemas/knowledge-entry.schema.json",
  "type": "object",
  "required": ["term", "tr", "def", "use", "cat", "example", "tags"],
  "additionalProperties": false,
  "properties": {
    "term": { "type": "string", "minLength": 1, "maxLength": 300 },
    "tr": { "type": "string", "minLength": 1, "maxLength": 300 },
    "abbr": { "type": "string", "maxLength": 80 },
    "def": { "type": "string", "minLength": 1, "maxLength": 20000 },
    "use": { "type": "string", "minLength": 1, "maxLength": 20000 },
    "cat": { "type": "string", "minLength": 1, "maxLength": 120 },
    "example": { "type": "string", "maxLength": 20000 },
    "tags": {
      "type": "array",
      "maxItems": 100,
      "items": { "type": "string", "maxLength": 100 }
    }
  }
}
