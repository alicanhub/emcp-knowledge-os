{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://emcp.example/schemas/publishing-object.schema.json",
  "type": "object",
  "required": [
    "id",
    "object_type",
    "title",
    "summary",
    "learning_objectives",
    "prerequisites",
    "difficulty_level",
    "estimated_study_time_minutes",
    "related_knowledge_entries",
    "related_topics",
    "related_calculators",
    "related_documents",
    "related_case_studies",
    "official_sources",
    "revision_history",
    "completion_status",
    "content_version",
    "review_status",
    "reviewer",
    "jurisdiction"
  ],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$" },
    "object_type": {
      "enum": [
        "topic",
        "learning_module",
        "content_pack",
        "learning_path",
        "handbook",
        "handbook_chapter",
        "case_study",
        "checklist",
        "document_guide"
      ]
    },
    "title": { "$ref": "#/$defs/localizedText" },
    "summary": { "$ref": "#/$defs/localizedText" },
    "learning_objectives": { "$ref": "#/$defs/localizedList" },
    "prerequisites": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "difficulty_level": {
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "estimated_study_time_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100000
    },
    "related_knowledge_entries": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "related_topics": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "related_calculators": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "related_documents": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "related_case_studies": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "official_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "revision_history": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/revision" }
    },
    "completion_status": { "enum": ["planned", "in_progress", "complete"] },
    "content_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "review_status": { "enum": ["draft", "in_review", "reviewed", "rejected"] },
    "reviewer": { "type": ["string", "null"] },
    "jurisdiction": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "child_topics": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "child_modules": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "child_packs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "child_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "chapters": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "required": ["en", "tr"],
      "additionalProperties": false,
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "tr": { "type": "string", "minLength": 1 }
      }
    },
    "localizedList": {
      "type": "object",
      "required": ["en", "tr"],
      "additionalProperties": false,
      "properties": {
        "en": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "tr": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["title", "url", "status"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "url": { "type": ["string", "null"], "format": "uri" },
        "status": { "enum": ["verified", "required"] }
      }
    },
    "revision": {
      "type": "object",
      "required": ["version", "date", "summary"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "summary": { "$ref": "#/$defs/localizedText" }
      }
    }
  }
}
