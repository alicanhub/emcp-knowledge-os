{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://emcp.example/schemas/knowledge-relationships.schema.json",
  "type": "object",
  "required": ["version", "relationships"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "relationships": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "array",
        "maxItems": 20,
        "items": { "type": "integer", "minimum": 0, "maximum": 999 }
      }
    }
  }
}
